{
  "name": "nexembot",
  "version": "0.1.0",
  "description": "TypeScript conversational flow engine for versioned chatbot definitions.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "demo:web": "npm --prefix examples/web-chatbot run dev -- --port 5173",
    "demo:web:build": "npm --prefix examples/web-chatbot run build",
    "demo:web:test": "npm --prefix examples/web-chatbot test -- --run"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
